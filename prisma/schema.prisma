generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ItemStatus {
  AVAILABLE
  RESERVED
  DONATED
}

enum PickupMethod {
  SELF_PICKUP
  DELIVERY
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum ReportTargetType {
  ITEM
  PROFILE
}

enum AccountType {
  PERSONAL
  ORGANIZATION
}

enum AdminActionType {
  BAN_USER
  UNBAN_USER
  WARN_USER
  DELETE_ITEM
  EDIT_ITEM
  RESOLVE_REPORT
  DISMISS_REPORT
  ADD_KEYWORD
  REMOVE_KEYWORD
  VERIFY_ORG
  REJECT_ORG
}

// ─── Models ─────────────────────────────────────────────

/// Synced from Supabase auth.users via a Postgres trigger.
/// Profile.id always matches the auth.users.id UUID.
model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?
  bio       String?
  district  String?
  region    String?
  country   String?
  role      UserRole @default(USER)

  // Account type
  accountType AccountType @default(PERSONAL)
  isVerified  Boolean     @default(false)
  verifiedAt  DateTime?

  // Ban / moderation fields
  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         Item[]
  messages      Message[]
  conversations ConversationParticipant[]
  favorites     Favorite[]

  // Admin relations
  reportsSubmitted Report[]      @relation("ReportReporter")
  reportsResolved  Report[]      @relation("ReportResolver")
  adminActions     AdminAction[]
  addedKeywords    BannedKeyword[]

  @@index([role])
  @@index([accountType])
  @@map("profiles")
}

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique
  icon String? // lucide icon name

  items Item[]

  @@map("categories")
}

model Item {
  id          String        @id @default(cuid())
  title       String
  description String
  images      String[]      // Supabase Storage URLs
  condition   ItemCondition
  pickupMethods PickupMethod[] @default([SELF_PICKUP])
  status      ItemStatus    @default(AVAILABLE)

  // Location
  latitude  Float
  longitude Float
  address   String?

  // Relations
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  donorId String @db.Uuid
  donor   Profile @relation(fields: [donorId], references: [id])

  conversations Conversation[]
  favorites     Favorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([latitude, longitude])
  @@index([categoryId])
  @@index([donorId])
  @@map("items")
}

model Conversation {
  id String @id @default(cuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())

  @@index([itemId])
  @@map("conversations")
}

model ConversationParticipant {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  profileId String  @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([conversationId, profileId])
  @@map("conversation_participants")
}

model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String  @db.Uuid
  sender   Profile @relation(fields: [senderId], references: [id])

  content   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model Favorite {
  id String @id @default(cuid())

  profileId String  @db.Uuid
  profile   Profile @relation(fields: [profileId], references: [id])

  itemId String
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([profileId, itemId])
  @@index([profileId])
  @@index([itemId])
  @@map("favorites")
}

// ─── Admin Models ───────────────────────────────────────

model Report {
  id String @id @default(cuid())

  reporterId String  @db.Uuid
  reporter   Profile @relation("ReportReporter", fields: [reporterId], references: [id])

  targetType ReportTargetType
  targetId   String
  reason     String
  description String?

  status    ReportStatus @default(PENDING)
  adminNote String?

  resolvedById String?   @db.Uuid
  resolvedBy   Profile?  @relation("ReportResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([targetType, targetId])
  @@index([reporterId])
  @@map("reports")
}

model AdminAction {
  id String @id @default(cuid())

  adminId String  @db.Uuid
  admin   Profile @relation(fields: [adminId], references: [id])

  actionType AdminActionType
  targetType String
  targetId   String
  details    String? // JSON-serialized context

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("admin_actions")
}

model BannedKeyword {
  id String @id @default(cuid())

  keyword  String  @unique
  isActive Boolean @default(true)

  addedById String  @db.Uuid
  addedBy   Profile @relation(fields: [addedById], references: [id])

  createdAt DateTime @default(now())

  @@index([keyword])
  @@map("banned_keywords")
}
